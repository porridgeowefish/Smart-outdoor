# Copy to backend/config/app.local.env for local or cloud runtime configuration.
# Real config files are ignored by git.

DATABASE_URL=postgresql+psycopg://smart_outdoor:smart_outdoor_dev_password@127.0.0.1:5432/smart_outdoor
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

ASSET_STORAGE_DIR=storage/assets
STORAGE_PROVIDER=local
STORAGE_PUBLIC_BASE_URL=/static/assets

# Tencent COS. Set STORAGE_PROVIDER=cos to enable.
COS_SECRET_ID=
COS_SECRET_KEY=
COS_TOKEN=
COS_BUCKET=
COS_REGION=
COS_CDN_BASE_URL=

USE_MOCK_AMAP=true
USE_MOCK_WEATHER=true
USE_MOCK_SEARCH=true
USE_MOCK_LLM=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=20

AMAP_WEB_SERVICE_KEY=
AMAP_REVERSE_GEOCODE_URL=https://restapi.amap.com/v3/geocode/regeo
QWEATHER_API_KEY=
WEATHER_DEVELOPER_HOST=devapi.qweather.com
TAVILY_API_KEY=
